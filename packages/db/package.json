{
  "name": "@workspace/db",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "description": "Schemas Drizzle + client Postgres compartilhado do Marketero (mini-CRM/funil).",
  "exports": {
    ".": "./src/index.ts",
    "./schemas": "./src/schemas/index.ts",
    "./client": "./src/client.ts",
    "./migrate": "./src/migrate.ts",
    "./seed": "./src/seed.ts"
  },
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun run src/seed.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "^0.40.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pg": "^8.11.10",
    "@workspace/typescript-config": "workspace:*",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5"
  }
}
