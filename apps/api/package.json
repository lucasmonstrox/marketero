{
  "name": "@workspace/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "API HTTP do Marketero (mini-CRM/funil) em Elysia (Bun).",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "lint": "eslint",
    "smoke": "bun run scripts/smoke.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.0",
    "@elysiajs/openapi": "^1.4.0",
    "@workspace/db": "workspace:*",
    "drizzle-orm": "^0.40.0",
    "drizzle-typebox": "^0.3.3",
    "elysia": "^1.4.10"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^9",
    "typescript": "^5"
  }
}
